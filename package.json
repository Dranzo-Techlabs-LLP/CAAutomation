{
  "name": "ca-practice-management-system",
  "private": true,
  "version": "0.1.0",
  "description": "Multi-tenant Practice Management System for Indian CA firms",
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "api:dev": "npm run start:dev -w apps/api",
